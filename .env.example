# ============================================================
#  content-engine env vars  (Monday -> Buffer automation)
#  Copy to .env.local for local dev; set the same in Vercel
#  Project Settings -> Environment Variables for production.
# ============================================================

# --- REUSED values you already have (from n8n / ~/.env.shared) ---
# Monday.com personal API token (same one your n8n "Monday.com account" cred uses)
MONDAY_API_TOKEN=

# Anthropic key for post-copy generation (Claude)
ANTHROPIC_API_KEY=

# --- NEW values you need to create ---
# Buffer personal API key: Buffer -> Settings -> API -> create key
BUFFER_API_KEY=

# OpenAI key for gpt-image-1 base image generation
OPENAI_API_KEY=

# Google service account JSON (single line, or base64) with Drive + Docs APIs
# enabled. Share the Social Media folder (1Wu0FgCbW1qddaispMxVNqdOt-suFJZqe)
# with this service account's client_email.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Vercel Blob auth. In production on Vercel this is handled automatically by
# OIDC (BLOB_STORE_ID + an injected VERCEL_OIDC_TOKEN) — no token needed.
# Only set BLOB_READ_WRITE_TOKEN to run/test Blob locally outside Vercel,
# or run `vercel env pull .env.local`.
# IMPORTANT: the Blob store MUST be created as a PUBLIC store — Buffer fetches
# the image URL anonymously at publish time.
BLOB_READ_WRITE_TOKEN=

# Shared secret protecting the cron + poll endpoints. Vercel sends this as a
# Bearer token on scheduled cron invocations; external pingers must match it.
CRON_SECRET=

# --- Optional ---
# Pause all sends to Buffer without code changes (set to "true" to dry-run).
BUFFER_DRY_RUN=false
